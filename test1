import pyautogui
import os
import time

print("Press Ctrl+C to quit.")

try:
    while True:
        # Get the current mouse position
        x, y = pyautogui.position()
        
        # Create a string to display the coordinates
        # .rjust() helps keep the numbers aligned as they change
        position_str = f"X: {str(x).rjust(4)}  Y: {str(y).rjust(4)}"
        
        # Print the coordinates to the same line in the terminal
        print(position_str, end='')
        
        # Use backspaces to "erase" the line for the next update
        print('\b' * len(position_str), end='', flush=True)
        
        # Small sleep to prevent high CPU usage
        time.sleep(0.05)

except KeyboardInterrupt:
    print('\nDone.')